{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.sarveshsea/memi",
  "title": "memi",
  "description": "Design-system memory for coding agents — Figma tokens, shadcn/ui codegen, Tailwind audits.",
  "version": "2.1.1",
  "websiteUrl": "https://memoire.cv",
  "repository": {
    "url": "https://github.com/sarveshsea/memi",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@memi-design/cli",
      "version": "2.1.1",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        },
        {
          "type": "positional",
          "value": "start"
        },
        {
          "type": "positional",
          "value": "--no-figma"
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "tool": "memi-release",
      "version": "2.1.1"
    }
  }
}
